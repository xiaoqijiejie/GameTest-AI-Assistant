import openai  # 或 from openai import OpenAI

# 配置API密钥
client = OpenAI(api_key="your-api-key")

# 调用AI生成测试用例
response = client.chat.completions.create(
    model="gpt-3.5-turbo",
    messages=[
        {"role": "system", "content": "你是一个资深游戏测试工程师"},
        {"role": "user", "content": f"请为'{feature}'功能生成测试用例"}
    ]
)
